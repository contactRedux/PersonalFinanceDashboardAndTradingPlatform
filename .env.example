# ════════════════════════════════════════════════════════════════════════════════
# PLATFORM ENVIRONMENT VARIABLES — copy to .env and fill in real values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                      # Required. development | production | test
APP_HOST=127.0.0.1                       # Optional. Bind address for uvicorn (default: 127.0.0.1)
APP_PORT=8000                            # Optional. HTTP port for the backend (default: 8000)
FRONTEND_URL=http://localhost:3000       # Optional. Used for CORS and redirect URLs
BACKEND_URL=http://localhost:8000        # Optional. Used by Next.js rewrites/proxy (default: http://localhost:8000)

# ─── Security ─────────────────────────────────────────────────────────────────
# Required. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-with-secrets-token-urlsafe-64-chars
JWT_ALGORITHM=HS256                      # Optional. Token signing algorithm (default: HS256)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15       # Optional. Access token lifetime in minutes (default: 15)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7         # Optional. Refresh token lifetime in days (default: 7)
TOTP_ISSUER_NAME=QuantNexus             # Optional. Issuer shown in authenticator apps (default: QuantNexus)

# ─── PostgreSQL / TimescaleDB ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/quantnexus
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/quantnexus

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=quantnexus

# ─── Market Data Providers ────────────────────────────────────────────────────
# Alpaca Markets (https://alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Polygon.io (https://polygon.io)
POLYGON_API_KEY=

# Alpha Vantage (https://www.alphavantage.co)
ALPHA_VANTAGE_API_KEY=

# Twelve Data (https://twelvedata.com)
TWELVE_DATA_API_KEY=

# Tiingo (https://tiingo.com)
TIINGO_API_KEY=

# Binance (https://binance.com — use api.binance.us for US users)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_BASE_URL=https://api.binance.us

# CoinGecko (https://coingecko.com/en/api)
COINGECKO_API_KEY=

# OANDA (https://developer.oanda.com) — forex
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_BASE_URL=https://api-fxpractice.oanda.com

# ─── News Providers ───────────────────────────────────────────────────────────
# NewsAPI (https://newsapi.org)
NEWSAPI_KEY=

# Benzinga (https://www.benzinga.com/apis)
BENZINGA_API_KEY=

# Twitter/X API v2 (https://developer.twitter.com)
TWITTER_BEARER_TOKEN=

# Reddit (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=QuantNexus/1.0

# Unusual Whales (https://unusualwhales.com/api)
UNUSUAL_WHALES_API_KEY=

# ─── AI / NLP ─────────────────────────────────────────────────────────────────
# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# HuggingFace (for model downloads — optional, models auto-download from hub)
HUGGINGFACE_TOKEN=

# ─── Macro / Economic Data ────────────────────────────────────────────────────
# FRED Federal Reserve Economic Data (https://fred.stlouisfed.org/docs/api/fred/)
FRED_API_KEY=

# ─── Fundamentals ─────────────────────────────────────────────────────────────
# Financial Modeling Prep (https://financialmodelingprep.com)
# Free tier: 250 requests/day. No code changes needed when upgrading to a paid
# plan — only a new API key with a higher quota.
FMP_API_KEY=

# ─── Social / Community ───────────────────────────────────────────────────────
# StockTwits (https://api.stocktwits.com/developers/docs)
# Read-only stream is free (no token needed). Optional access token for higher
# rate limits and write access.
STOCKTWITS_ACCESS_TOKEN=

# ─── Earnings Transcripts ─────────────────────────────────────────────────────
# EarningsCall.ai (https://earningscall.biz)
# Free tier: limited recent transcript access. No code changes needed when
# upgrading to Individual plan ($9/mo for 1,000 transcripts/month).
EARNINGSCALL_API_KEY=

# ─── Fundamentals (additional providers) ─────────────────────────────────────
# FactSet Open API (https://developer.factset.com)
# Free developer tier: ~250 requests/day. Format: "username:apikey"
FACTSET_API_KEY=

# OpenFIGI — Bloomberg Open Symbology identifier mapping (https://www.openfigi.com)
# Free, no key required (10 req/min). Optional key raises limit to 25 req/min.
OPENFIGI_API_KEY=

# ─── Reuters / Refinitiv (license required) ──────────────────────────────────
# LSEG/Refinitiv RDP App Key (https://developers.refinitiv.com)
# Requires a paid Eikon/Workspace/RDP license. See docs/adr/ADR-009-reuters-refinitiv.md
# for the activation path. Leave empty to disable (no error, no crash).
# SDK install (after license): pip install refinitiv-data>=1.0.0
REFINITIV_APP_KEY=



# ─── CORS ─────────────────────────────────────────────────────────────────────
# Optional. Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3000

# ─── Market Data Provider ─────────────────────────────────────────────────────
# Optional. Active market data provider: alpaca | yfinance | polygon (default: alpaca)
MARKET_DATA_PROVIDER=alpaca

# ─── Observability ────────────────────────────────────────────────────────────
# Optional. Set to "true" to expose /metrics for Prometheus scraping (default: true)
ENABLE_METRICS=true
PROMETHEUS_PORT=9090                     # Optional. Prometheus scrape port used in docker-compose (default: 9090)

# Grafana admin credentials (change from defaults in production)
GRAFANA_ADMIN_USER=admin                 # Optional. Grafana admin username (default: admin)
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password  # Required in production. Grafana admin password

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Configured in app/middleware/rate_limit.py:
#   Auth endpoints:  10 req / 60s per IP
#   All other APIs: 120 req / 60s per IP
# Adjust _AUTH_LIMIT and _API_LIMIT constants as needed.

# ─── Audit Logging ────────────────────────────────────────────────────────────
# Audit log records: auth.login_success, auth.login_failed, auth.logout,
# auth.totp_enabled, auth.totp_failed
# Stored in PostgreSQL audit_log table.
# Retention: manage via pg_partman or manual TRUNCATE partitions.

# ─── Tick / Streaming Tuning ──────────────────────────────────────────────────
# Optional. Comma-separated symbols for the live tick recorder (default: AAPL,MSFT,TSLA)
TICK_SYMBOLS=AAPL,MSFT,TSLA
# Optional. Maximum number of ticks per flush batch (default: 500)
TICK_BATCH_SIZE=500
# Optional. Maximum age in seconds before a partial batch is flushed (default: 1.0)
TICK_BATCH_AGE_S=1.0

# ─── ML Model Weights ─────────────────────────────────────────────────────────
# Optional. Directory where trained ML model weights are stored (default: /app/data/ml_weights)
ML_WEIGHTS_DIR=/app/data/ml_weights

# ─── Live Data Integration (for CI + live trading) ───────────────────────────
# These keys unlock real market data in tests and the live trading feed.
# Leave empty to use demo/simulation fallbacks.

# Alpaca paper trading (https://paper-api.alpaca.markets)
# Uses ALPACA_API_KEY / ALPACA_SECRET_KEY from above section.
# Set ALPACA_BASE_URL=https://paper-api.alpaca.markets for paper trading.

# Polygon.io market data (https://polygon.io)
# POLYGON_API_KEY is defined above.

# FRED economic data (https://fred.stlouisfed.org/docs/api/fred/)
# FRED_API_KEY is defined above.

# ─── E2E / Playwright Test Settings ──────────────────────────────────────────
# Optional. Base URL for Playwright tests (default: http://localhost:3000)
PLAYWRIGHT_BASE_URL=http://localhost:3000
# Optional. Set to "true" in CI to enforce strict mode (no retries, single worker)
CI=

# ─── E2E Test Credentials ─────────────────────────────────────────────────────
# Optional. Used by Playwright tests to log in as a real user.
# Create this user via POST /api/v1/auth/register before running E2E tests.
# Leave empty to skip credential-gated tests (e.g. dashboard, trading, watchlist).
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=replace-with-test-user-password
# Optional. Set to "true" if the test user has TOTP enabled (default: false)
TOTP_TEST_ENABLED=false
